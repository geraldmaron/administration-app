        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ (() => { const request = $('Incoming Job Request').item.json.body || {}; const bundles = Array.isArray(request.bundles) ? request.bundles : []; const count = typeof request.count === 'number' ? request.count : 1; return { jobId: $json.jobId, status: 'running', currentPhase: 'starting', currentMessage: 'n8n orchestrator: starting bundle fan-out', totalCount: bundles.length * count }; })() }}",
        "options": {},
        "infoMessage": ""
