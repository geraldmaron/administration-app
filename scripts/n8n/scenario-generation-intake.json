        "sendHeaders": true,
        "specifyHeaders": "keypair",
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ (() => { const d = { ...$json }; delete d.targetUrl; return d; })() }}",
        "options": {
          "timeout": 540000
        },
        "infoMessage": ""
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "UBv01nlXlbZjNRBJ",
