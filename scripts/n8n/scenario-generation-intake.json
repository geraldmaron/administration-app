        "specifyBody": "json",
        "jsonBody": "={{ { jobId: $('Queue Generation Job').item.json.jobId } }}",
        "options": {
          "timeout": 10000
        },
        "infoMessage": ""
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "UBv01nlXlbZjNRBJ",
          "name": "admin-secret"
        }
      },
      "id": "heartbeat-bundle",
      "name": "Heartbeat Bundle",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1580,
        500
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const results = $input.all();\nconst jobId = $('Queue Generation Job').item.json.jobId || '';\n\nlet totalCompleted = 0;\nlet totalFailed = 0;\nconst allErrors = [];\n\nfor (const item of results) {\n  const r = item.json;\n  totalCompleted += typeof r.completedCount === 'number' ? r.completedCount : 0;\n  totalFailed += typeof r.failedCount === 'number' ? r.failedCount : 0;\n  if (Array.isArray(r.errors)) {\n    allErrors.push(...r.errors);\n  }\n}\n\nconst status = totalFailed > 0 && totalCompleted === 0 ? 'failed' : 'completed';\n\nreturn [{ json: { jobId, status, totalCompleted, totalFailed, errors: allErrors } }];",
        "notice": ""
      },
      "id": "aggregate-results",
      "name": "Aggregate Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1580,
        300
