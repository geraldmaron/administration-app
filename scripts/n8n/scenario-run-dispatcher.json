    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const request = $(\"Incoming Run Request\").item.json.body || {};\nconst jobId = request.jobId;\nconst bundles = Array.isArray(request.bundles) ? request.bundles : [];\nconst count = typeof request.count === \"number\" ? request.count : 1;\n\nconst mc = request.modelConfig || {};\nconst isOllamaJob = Object.values(mc).some(v => typeof v === \"string\" && v.startsWith(\"ollama:\"));\nconst CLOUD_URL = \"https://us-central1-the-administration-3a072.cloudfunctions.net/processGenerationBundle\";\nconst LOCAL_URL = \"http://100.65.198.124:3099/processGenerationBundle\";\nconst targetUrl = isOllamaJob ? LOCAL_URL : CLOUD_URL;\n\nconst scope = {\n  scopeTier: request.scopeTier || \"universal\",\n  scopeKey: request.scopeKey || \"universal\",\n  sourceKind: request.sourceKind || \"evergreen\",\n  regions: request.regions || [],\n  region: request.region,\n  applicable_countries: request.applicable_countries || [],\n  exclusivityReason: request.exclusivityReason,\n  clusterId: request.clusterId,\n};\n\nconst payload = {\n  jobId,\n  count,\n  mode: request.mode || \"manual\",\n  lowLatencyMode: request.lowLatencyMode || false,\n  modelConfig: mc,\n  dryRun: request.dryRun || false,\n  newsContext: request.newsContext || [],\n  totalBundles: bundles.length,\n  ...scope,\n};\n\nreturn bundles.map(bundle => ({\n  json: {\n    meta: { targetUrl, asyncDispatch: isOllamaJob },\n    payload: { ...payload, bundle },\n  }\n}));",
        "notice": ""
      },
      "id": "prepare-bundles-run",
      "name": "Prepare Bundle Items",
      "type": "n8n-nodes-base.code",
