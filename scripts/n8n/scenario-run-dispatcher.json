        "jsonBody": "={{ (() => { const request = $(\"Incoming Run Request\").item.json.body || {}; const bundles = Array.isArray(request.bundles) ? request.bundles : []; const count = typeof request.count === \"number\" ? request.count : 1; return { jobId: request.jobId, status: \"running\", currentPhase: \"starting\", currentMessage: \"n8n runner: starting bundle fan-out\", totalCount: bundles.length * count }; })() }}",
