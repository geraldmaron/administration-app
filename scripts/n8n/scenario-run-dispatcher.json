      "position": [
        1320,
        500
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const results = $input.all();\nconst jobId = $(\"Incoming Run Request\").item.json.body.jobId || \"\";\n\nconst isAsync = results.some(item => item.json?.queued === true);\nif (isAsync) {\n  return [{ json: { jobId, asyncDispatch: true, status: \"dispatched\" } }];\n}\n\nlet totalCompleted = 0;\nlet totalFailed = 0;\nconst allErrors = [];\n\nfor (const item of results) {\n  const r = item.json;\n  totalCompleted += typeof r.completedCount === \"number\" ? r.completedCount : 0;\n  totalFailed += typeof r.failedCount === \"number\" ? r.failedCount : 0;\n  if (Array.isArray(r.errors)) {\n    allErrors.push(...r.errors);\n  }\n}\n\nconst status = totalFailed > 0 && totalCompleted === 0 ? \"failed\" : \"completed\";\n\nreturn [{ json: { jobId, asyncDispatch: false, status, totalCompleted, totalFailed, errors: allErrors } }];",
        "notice": ""
      },
