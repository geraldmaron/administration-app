{
  "name": "admin-app",
  "version": "1.0.0",
  "private": true,
  "description": "Admin CLI for scenario and bundle management (generate, list, delete, export, audit)",
  "type": "module",
  "bin": {
    "admin-app": "./bin/scenario-loops.js"
  },
